////////////////////////////////////////////////////////////////////////////////
// PR Binary Search Kusto Setup
//
// Purpose:
// 1. Keep `PRBinarySearchFailureInfo` as the failure-analyzer source table.
// 2. Add execution-level tables so one failure can be traced to:
//    - each binary-search round
//    - each tested commit
//    - each Azure DevOps pipeline run
//    - each Elastictest test plan id
// 3. Add a summary table for the final root-cause conclusion.
////////////////////////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////
// Optional helper function:
// Build a stable join key from the existing failure analyzer table.
////////////////////////////////////////////////////////////////////////////////
.create-or-alter function with (
    folder = "PRBinarySearch",
    docstring = "Normalized failure analyzer view with FailureJoinKey for binary-search joins"
) PRBinarySearchFailureInfoView() {
    PRBinarySearchFailureInfo
    | extend FailureJoinKey = strcat(
        SourceRepo, "|", Branch, "|", TriggerType, "|",
        CheckerType, "|", FilePath, "|", ModulePath, "|", TestCase
    )
}

////////////////////////////////////////////////////////////////////////////////
// Table 1: execution records
// One row per failure x round x commit x stage(build/test).
////////////////////////////////////////////////////////////////////////////////
.create-merge table PRBinarySearchLog (
    SearchRunId: string,
    AnalyzerRunId: string,
    FailureJoinKey: string,
    TriggerType: string,
    SourceRepo: string,
    Branch: string,
    CheckerType: string,
    FilePath: string,
    ModulePath: string,
    TestCase: string,
    RoundNumber: int,
    CommitSha: string,
    Stage: string,
    Verdict: string,
    IsBad: bool,
    PipelineDefinitionId: int,
    PipelineRunId: string,
    PipelineUrl: string,
    Status: string,
    Result: string,
    BuildReason: string,
    ImpactAreaInfo: dynamic,
    RawRecord: dynamic,
    UploadTime: datetime
)

.create-or-alter table PRBinarySearchLog ingestion json mapping "PRBinarySearchLogMappingV1" @'[
  {"column":"SearchRunId","Properties":{"path":"$.SearchRunId"}},
  {"column":"AnalyzerRunId","Properties":{"path":"$.AnalyzerRunId"}},
  {"column":"FailureJoinKey","Properties":{"path":"$.FailureJoinKey"}},
  {"column":"TriggerType","Properties":{"path":"$.TriggerType"}},
  {"column":"SourceRepo","Properties":{"path":"$.SourceRepo"}},
  {"column":"Branch","Properties":{"path":"$.Branch"}},
  {"column":"CheckerType","Properties":{"path":"$.CheckerType"}},
  {"column":"FilePath","Properties":{"path":"$.FilePath"}},
  {"column":"ModulePath","Properties":{"path":"$.ModulePath"}},
  {"column":"TestCase","Properties":{"path":"$.TestCase"}},
  {"column":"RoundNumber","Properties":{"path":"$.RoundNumber"}},
  {"column":"CommitSha","Properties":{"path":"$.CommitSha"}},
  {"column":"Stage","Properties":{"path":"$.Stage"}},
  {"column":"Verdict","Properties":{"path":"$.Verdict"}},
  {"column":"IsBad","Properties":{"path":"$.IsBad"}},
  {"column":"PipelineDefinitionId","Properties":{"path":"$.PipelineDefinitionId"}},
  {"column":"PipelineRunId","Properties":{"path":"$.PipelineRunId"}},
  {"column":"PipelineUrl","Properties":{"path":"$.PipelineUrl"}},
  {"column":"Status","Properties":{"path":"$.Status"}},
  {"column":"Result","Properties":{"path":"$.Result"}},
  {"column":"BuildReason","Properties":{"path":"$.BuildReason"}},
  {"column":"ImpactAreaInfo","Properties":{"path":"$.ImpactAreaInfo"}},
  {"column":"RawRecord","Properties":{"path":"$.RawRecord"}},
  {"column":"UploadTime","Properties":{"path":"$.UploadTime"}}
]'

////////////////////////////////////////////////////////////////////////////////
// Table 2: pipeline-run -> Elastictest test plan ids
// One row per failure x commit x pipeline run x test plan id.
////////////////////////////////////////////////////////////////////////////////
.create-merge table PRBinarySearchTestPlanMap (
    SearchRunId: string,
    FailureJoinKey: string,
    PipelineRunId: string,
    RoundNumber: int,
    CommitSha: string,
    TestPlanId: string,
    UploadTime: datetime
)

.create-or-alter table PRBinarySearchTestPlanMap ingestion json mapping "PRBinarySearchTestPlanMapMappingV1" @'[
  {"column":"SearchRunId","Properties":{"path":"$.SearchRunId"}},
  {"column":"FailureJoinKey","Properties":{"path":"$.FailureJoinKey"}},
  {"column":"PipelineRunId","Properties":{"path":"$.PipelineRunId"}},
  {"column":"RoundNumber","Properties":{"path":"$.RoundNumber"}},
  {"column":"CommitSha","Properties":{"path":"$.CommitSha"}},
  {"column":"TestPlanId","Properties":{"path":"$.TestPlanId"}},
  {"column":"UploadTime","Properties":{"path":"$.UploadTime"}}
]'

////////////////////////////////////////////////////////////////////////////////
// Table 3: final binary-search summary
// One row per failure.
////////////////////////////////////////////////////////////////////////////////
.create-merge table PRBinarySearchResult (
    SearchRunId: string,
    AnalyzerRunId: string,
    FailureJoinKey: string,
    TriggerType: string,
    SourceRepo: string,
    Branch: string,
    CheckerType: string,
    FilePath: string,
    ModulePath: string,
    TestCase: string,
    LikelyIssueClose: bool,
    RootCauseType: string,
    RootCauseValue: string,
    IssueRepo: string,
    IssueNumber: string,
    IssueClosedAt: datetime,
    BadCommit: string,
    PRLink: string,
    TotalRounds: int,
    SearchCompleted: bool,
    FinalRange: dynamic,
    TestedPipelineRunIds: dynamic,
    TestedTestPlanIds: dynamic,
    RawSummary: dynamic,
    UploadTime: datetime
)

.create-or-alter table PRBinarySearchResult ingestion json mapping "PRBinarySearchResultMappingV1" @'[
  {"column":"SearchRunId","Properties":{"path":"$.SearchRunId"}},
  {"column":"AnalyzerRunId","Properties":{"path":"$.AnalyzerRunId"}},
  {"column":"FailureJoinKey","Properties":{"path":"$.FailureJoinKey"}},
  {"column":"TriggerType","Properties":{"path":"$.TriggerType"}},
  {"column":"SourceRepo","Properties":{"path":"$.SourceRepo"}},
  {"column":"Branch","Properties":{"path":"$.Branch"}},
  {"column":"CheckerType","Properties":{"path":"$.CheckerType"}},
  {"column":"FilePath","Properties":{"path":"$.FilePath"}},
  {"column":"ModulePath","Properties":{"path":"$.ModulePath"}},
  {"column":"TestCase","Properties":{"path":"$.TestCase"}},
  {"column":"LikelyIssueClose","Properties":{"path":"$.LikelyIssueClose"}},
  {"column":"RootCauseType","Properties":{"path":"$.RootCauseType"}},
  {"column":"RootCauseValue","Properties":{"path":"$.RootCauseValue"}},
  {"column":"IssueRepo","Properties":{"path":"$.IssueRepo"}},
  {"column":"IssueNumber","Properties":{"path":"$.IssueNumber"}},
  {"column":"IssueClosedAt","Properties":{"path":"$.IssueClosedAt"}},
  {"column":"BadCommit","Properties":{"path":"$.BadCommit"}},
  {"column":"PRLink","Properties":{"path":"$.PRLink"}},
  {"column":"TotalRounds","Properties":{"path":"$.TotalRounds"}},
  {"column":"SearchCompleted","Properties":{"path":"$.SearchCompleted"}},
  {"column":"FinalRange","Properties":{"path":"$.FinalRange"}},
  {"column":"TestedPipelineRunIds","Properties":{"path":"$.TestedPipelineRunIds"}},
  {"column":"TestedTestPlanIds","Properties":{"path":"$.TestedTestPlanIds"}},
  {"column":"RawSummary","Properties":{"path":"$.RawSummary"}},
  {"column":"UploadTime","Properties":{"path":"$.UploadTime"}}
]'

////////////////////////////////////////////////////////////////////////////////
// Dashboard helper functions
//
// Use these functions in Grafana panel queries instead of raw table scans to
// avoid inflated counts from:
//   - PRBinarySearchFailureInfo: same AnalyzerRunId re-ingested daily → many rows
//   - PRBinarySearchResult:      same episode retried → many SearchRunIds per failure
//
// Each failure episode (AnalyzerRunId) may produce multiple rows in both tables.
// These functions return one row per episode so dashboard panels show actual
// failure count rather than ingest/retry count.
//
// Precedence for "best" result per episode (PRBinarySearchResult*):
//   1. SearchCompleted=true and BadCommit found  (fully resolved)
//   2. SearchCompleted=true, no BadCommit         (completed, inconclusive)
//   3. In-progress / timed-out                   (still running or failed)
// Within the same precedence tier, the most recent UploadTime wins.
////////////////////////////////////////////////////////////////////////////////

// One row per failure episode — first detection time.
// Use for "Detected" counts and any panel reading PRBinarySearchFailureInfo.
// UploadTime on the returned row = earliest ingest time = true first-detection date.
.create-or-alter function with (
    folder = "PRBinarySearch",
    docstring = "One row per failure episode (AnalyzerRunId) using earliest UploadTime as detection date — deduplicated for dashboard use"
) PRBinarySearchFailureInfoLatest() {
    PRBinarySearchFailureInfo
    | summarize arg_min(UploadTime, *) by AnalyzerRunId
}

// Best result per failure episode.
// Use for "Detected Issues", "Bad Commits Found", and per-failure summary panels.
.create-or-alter function with (
    folder = "PRBinarySearch",
    docstring = "Best PRBinarySearchResult per AnalyzerRunId — one row per failure episode, deduplicated for dashboard use"
) PRBinarySearchResultLatest() {
    PRBinarySearchResult
    | extend _rank = case(
        SearchCompleted == true and isnotempty(BadCommit), 2,
        SearchCompleted == true,                           1,
                                                           0)
    | order by AnalyzerRunId asc, FailureJoinKey asc, _rank desc, UploadTime desc
    | summarize take_any(*) by AnalyzerRunId, FailureJoinKey
    | project-away _rank
}

// Log rows from the canonical search run per failure episode.
// Use for "Search Rounds", "Commits Tested", and per-round detail panels.
.create-or-alter function with (
    folder = "PRBinarySearch",
    docstring = "PRBinarySearchLog rows scoped to the canonical SearchRunId per failure episode"
) PRBinarySearchLogLatest() {
    let canonical_runs = PRBinarySearchResultLatest()
        | project AnalyzerRunId, FailureJoinKey, CanonicalRunId = SearchRunId;
    PRBinarySearchLog
    | join kind=inner canonical_runs on AnalyzerRunId, FailureJoinKey
    | where SearchRunId == CanonicalRunId
    | project-away CanonicalRunId, AnalyzerRunId1, FailureJoinKey1
}
