topology:
  VMs:
{%- for vm in vm_list %}
    {{ vm.name }}:
      vlans:
      {%- for vlan_id in vm.vlans %}
        - {{ vlan_id }}
      {%- endfor %}
      vm_offset: {{ vm.vm_offset }}
{%- endfor %}

configuration_properties:
  common:
    dut_asn: {{ dut.asn }}
    dut_type: BackEndSpineRouter
    nhipv4: 10.10.246.254
    nhipv6: FC0A::FF
    podset_number: 400
    tor_number: 16
    tor_subnet_number: 8
    max_tor_subnet_number: 32
    tor_subnet_size: 128
  leaf:
    swrole: leaf
  peer-leaf:
    swrole: peer-leaf

configuration:
{%- for vm in vm_list %}
  {{ vm.name }}:
    properties:
    - common
    {%- if vm.role == 't1' %}
    - leaf
    {%- elif vm.role == 'pt1' %}
    - peer-leaf
    {%- endif %}
    bgp:
      asn: {{ vm.asn }}
      peers:
        {{ vm.peer_asn }}:
          - {{ vm.dut_intf_ipv4 }}
          - {{ vm.dut_intf_ipv6 }}
    interfaces:
      Loopback0:
        ipv4: {{ vm.loopback_ipv4 }}/32
        ipv6: {{ vm.loopback_ipv6 }}/128
      {%- if vm.num_lags > 0 %}
      {%- for idx in range(vm.num_lags) %}
      Ethernet{{ idx + 1 }}:
        lacp: 1
      {%- endfor %}
      Port-Channel1:
        ipv4: {{ vm.pc_intf_ipv4 }}/31
        ipv6: {{ vm.pc_intf_ipv6 }}/126
      {%- else %}
      Ethernet1:
        ipv4: {{ vm.pc_intf_ipv4 }}/31
        ipv6: {{ vm.pc_intf_ipv6 }}/126
      {%- endif %}
    bp_interface:
      ipv4: {{ vm.bp_ipv4 }}/22
      ipv6: {{ vm.bp_ipv6 }}/64
{%- endfor %}
